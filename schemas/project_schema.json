{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Marylin-Alvarado/IEEE830/schemas/project_schema.json",
  "title": "SGR - Project Schema",
  "description": "Esquema de validación para proyectos y requisitos del Sistema de Generación de Requisitos (IEEE 830-1998 & EARS)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "nombre_proyecto",
    "objetivo_general",
    "descripcion_dominio",
    "fecha_registro"
  ],
  "properties": {
    "nombre_proyecto": {
      "type": "string",
      "minLength": 1,
      "description": "Nombre del proyecto registrado en el SGR"
    },
    "objetivo_general": {
      "type": "string",
      "minLength": 1,
      "description": "Objetivo general del proyecto"
    },
    "descripcion_dominio": {
      "type": "string",
      "minLength": 1,
      "description": "Descripción del dominio del proyecto"
    },
    "fecha_registro": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}( \\d{2}:\\d{2}:\\d{2})?$",
      "description": "Fecha de registro en formato ISO (YYYY-MM-DD o YYYY-MM-DD HH:MM:SS)"
    },
    "requisitos": {
      "type": "array",
      "description": "Lista de requisitos funcionales asociados al proyecto",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "codigo",
          "descripcion",
          "sintaxis_ears",
          "tipo_ieee830"
        ],
        "properties": {
          "codigo": {
            "type": "string",
            "pattern": "^RF-\\d{2}$",
            "description": "Código único del requisito (ej. RF-01, RF-42)"
          },
          "descripcion": {
            "type": "string",
            "minLength": 1,
            "description": "Descripción textual del requisito en sintaxis EARS"
          },
          "sintaxis_ears": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "when",
              "the_system_shall"
            ],
            "properties": {
              "when": {
                "type": "boolean",
                "const": true,
                "description": "Indica si el requisito contiene la palabra clave WHEN (condición disparadora)"
              },
              "the_system_shall": {
                "type": "boolean",
                "const": true,
                "description": "Indica si el requisito contiene la frase clave THE SYSTEM SHALL (comportamiento esperado)"
              }
            }
          },
          "tipo_ieee830": {
            "type": "string",
            "enum": [
              "functional",
              "non-functional",
              "interface",
              "business_rule"
            ],
            "description": "Tipo de requisito según la clasificación IEEE 830-1998"
          }
        }
      }
    }
  }
}
